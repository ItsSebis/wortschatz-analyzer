{
  "manifest_version": 3,
  "name": "Spotify Transcript Exporter Pro",
  "version": "2.0",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8081/*","http://10.5.1.11:8081/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "commands": {
    "popup": {
      "suggested_key": {
        "default": "Ctrl+Shift+E"
      },
    "description": "Open PopUp"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["content.js"]
    }
  ]
}